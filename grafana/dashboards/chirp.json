{
  "title": "Chirp - Application Dashboard",
  "uid": "chirp-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(minitwit_http_responses_total[1m])",
          "legendFormat": "Requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (4xx + 5xx req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total{code=~\"4..|5..\"}[1m])",
          "legendFormat": "{{code}} errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Request Duration Percentiles (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "minitwit_cpu_load_percent",
          "legendFormat": "Working Set (MB)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      }
    },
    {
      "id": 5,
      "title": "Active HTTP Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 8 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress)",
          "legendFormat": "In Progress"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Cheeps Created (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\"} |= \"CheepCreated\" [1m]))",
          "legendFormat": "Cheeps/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 7,
      "title": "Follows Created (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\"} |= \"FollowCreated\" [1m]))",
          "legendFormat": "Follows/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      }
    },
    {
      "id": 8,
      "title": "New Registrations (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\"} |= \"User created a new account\" [1m]))",
          "legendFormat": "Registrations/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      }
    },
    {
      "id": 9,
      "title": "Logins (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\"} |= \"User logged in\" [1m]))",
          "legendFormat": "Logins/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "light-green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 10,
      "title": "Login Failures (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\"} |= \"LoginFailed\" [1m]))",
          "legendFormat": "Failures/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "id": 11,
      "title": "Error Logs (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"chirp-web\", level=\"Error\"} [1m]))",
          "legendFormat": "Errors/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 12,
      "title": "Total HTTP Responses (all time)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 32, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "minitwit_http_responses_total",
          "legendFormat": "Total Responses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "HTTP Request Rate by Status Code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 18, "y": 32, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total[1m])",
          "legendFormat": "{{code}} {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "loki", "value": "loki" },
        "hide": 2
      }
    ]
  }
}
