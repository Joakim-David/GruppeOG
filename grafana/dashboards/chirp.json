{
  "title": "Chirp - Application Dashboard",
  "uid": "chirp-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "title": "App Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 1,
      "title": "App Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"itu-minitwit-app\"}",
          "legendFormat": "Chirp"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Chirp application is UP", "color": "green", "index": 0 } } },
            { "type": "value", "options": { "0": { "text": "Chirp application is DOWN", "color": "red", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Total HTTP Responses",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "minitwit_http_responses_total",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Failed Requests (4xx + 5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "sum(http_requests_received_total{code=~\"4..|5..\"})",
          "legendFormat": "Failed"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },

    {
      "id": 101,
      "title": "HTTP Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 4,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(minitwit_http_responses_total[1m])",
          "legendFormat": "Requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "HTTP Error Rate (4xx + 5xx req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total{code=~\"4..|5..\"}[1m])",
          "legendFormat": "{{code}} errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(minitwit_request_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "lineInterpolation": "smooth" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "p90" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Avg Response Time by Endpoint (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 9 },
      "targets": [
        {
          "expr": "sum by (action) (rate(http_request_duration_seconds_sum[5m])) / sum by (action) (rate(http_request_duration_seconds_count[5m])) * 1000",
          "legendFormat": "{{action}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Request Rate by Status Code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total[1m])",
          "legendFormat": "{{code}} {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 102,
      "title": "Process & Runtime",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 9,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 33, "w": 6, "h": 8 },
      "targets": [{ "expr": "minitwit_cpu_load_percent", "legendFormat": "CPU" }],
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Working Set Memory (MB)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 6, "y": 33, "w": 6, "h": 8 },
      "targets": [{ "expr": "minitwit_memory_working_set_mb", "legendFormat": "WS" }],
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "max": 1024,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 512 },
              { "color": "red", "value": 768 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "GC Heap Size (MB)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 33, "w": 6, "h": 8 },
      "targets": [
        { "expr": "dotnet_total_memory_bytes / 1024 / 1024", "legendFormat": "Heap" }
      ],
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "max": 512,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 256 },
              { "color": "red", "value": 384 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Thread Count",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 18, "y": 33, "w": 6, "h": 8 },
      "targets": [{ "expr": "process_num_threads", "legendFormat": "Threads" }],
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 150 }
            ]
          }
        }
      }
    },
    {
      "id": 17,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 41, "w": 12, "h": 8 },
      "targets": [
        { "expr": "minitwit_cpu_load_percent", "legendFormat": "CPU %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 18,
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 41, "w": 12, "h": 8 },
      "targets": [
        { "expr": "minitwit_memory_working_set_mb", "legendFormat": "Working Set (MB)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 103,
      "title": "Business Activity",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 13,
      "title": "Cheeps Created (per minute)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(cheeps_send_total[1m]) * 60", "legendFormat": "Cheeps/min" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 14,
      "title": "Follows Created (per minute)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 42, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(user_follows_total[1m]) * 60", "legendFormat": "Follows/min" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 15,
      "title": "New Registrations (per minute)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 8 },
      "targets": [
        { "expr": "rate(user_registrations_total[1m]) * 60", "legendFormat": "Registrations/min" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 104,
      "title": "Error Tracking",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 58, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 16,
      "title": "Error Logs (per minute)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 59, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"minitwit\"} |~ \"(?i)exception|error\" [1m]))",
          "legendFormat": "Errors/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "loki", "value": "loki" },
        "hide": 2
      }
    ]
  }
}
